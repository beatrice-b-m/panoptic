# panoptic environment variables
# Export these in your shell, add to the launchd plist EnvironmentVariables,
# or pass as CLI flags (see: python3 panoptic_cli.py serve --help).

# Terminal font family (must be installed on the client/browser device).
# Default: "'Hack Nerd Font', 'Hack Nerd Font Mono', Menlo, Consolas, monospace"
# TERMINAL_FONT_FAMILY="JetBrains Mono, Fira Code, monospace"

# TLS — set both to serve over HTTPS.
# Provision certs via: tailscale cert --cert-file cert.pem --key-file key.pem <machine>.ts.net
# TLS_CERT=/path/to/cert.pem
# TLS_KEY=/path/to/key.pem

# beamux — used for pane-layout creation when spawning sessions with layouts.
# Install from https://github.com/beatrice-b-m/beamux — default: "beamux" (looked up in PATH).
# BEAMUX_BINARY=/path/to/beamux

# Multi-host — path to the JSON file that stores host configurations.
# Default: hosts.json in the project directory.
# HOSTS_CONFIG_PATH=/path/to/hosts.json

# SSH — connect timeout (seconds) for remote host polling.
# Default: 5
# SSH_CONNECT_TIMEOUT=5
